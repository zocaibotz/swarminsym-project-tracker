{
  "name": "repo",
  "version": "1.0.0",
  "description": "A comprehensive web application to track each phase of every SWARMINSYM project from prompt to deployment, displaying all details including debugging, problems, resolutions, and AI decisions in an intuitive visual timeline with professional UX.",
  "main": "index.js",
  "directories": {
    "doc": "docs"
  },
  "scripts": {
    "test": "vitest run",
    "prisma:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:seed": "prisma db seed",
    "db:test": "node scripts/test-db-connection.js",
    "migrate:postgresql": "bash scripts/migrate-provider.sh postgresql",
    "migrate:mysql": "bash scripts/migrate-provider.sh mysql",
    "migrate:sqlserver": "bash scripts/migrate-provider.sh sqlserver"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zocaibotz/swarminsym-project-tracker.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/zocaibotz/swarminsym-project-tracker/issues"
  },
  "homepage": "https://github.com/zocaibotz/swarminsym-project-tracker#readme",
  "dependencies": {
    "@prisma/client": "^6.16.0",
    "prisma": "^6.16.0"
  },
  "devDependencies": {
    "vitest": "^4.1.0"
  },
  "prisma": {
    "seed": "node prisma/seed.js"
  }
}
