{
  "name": "swarminsym-project-tracker",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "test": "vitest run",
    "test:red": "vitest run tests/observability.red.test.ts",
    "test:green": "vitest run tests/observability.green.test.ts",
    "build": "tsc -p tsconfig.json",
    "security:npm-audit": "npm audit --audit-level=high",
    "security:semgrep": "semgrep --config auto src tests"
  },
  "dependencies": {
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/resources": "^1.30.1",
    "@opentelemetry/sdk-trace-base": "^1.30.1",
    "@opentelemetry/sdk-trace-node": "^1.30.1",
    "elastic-apm-node": "^4.8.1",
    "express": "^4.21.2",
    "pino": "^9.3.2"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.13.10",
    "typescript": "^5.8.2",
    "vitest": "^2.1.8"
  }
}
