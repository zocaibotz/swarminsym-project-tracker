generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id          String      @id @default(cuid())
  email       String      @unique
  name        String
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  projects    Project[]
  decisions   Decision[]
  problems    Problem[]
  resolutions Resolution[]
  debugLogs   DebugLog[]
  artifacts   Artifact[]
}

model Project {
  id          String   @id @default(cuid())
  name        String
  description String?
  status      String   @default("active")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  ownerId     String
  owner       User     @relation(fields: [ownerId], references: [id])
  phases      Phase[]

  @@index([ownerId])
}

model Phase {
  id          String       @id @default(cuid())
  projectId   String
  name        String
  order       Int
  status      String       @default("pending")
  startedAt   DateTime?
  completedAt DateTime?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  project     Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  detail      PhaseDetail?
  decisions   Decision[]
  problems    Problem[]
  resolutions Resolution[]
  debugLogs   DebugLog[]
  artifacts   Artifact[]

  @@index([projectId])
  @@unique([projectId, order])
}

model PhaseDetail {
  id               String   @id @default(cuid())
  phaseId          String   @unique
  objective        String
  notes            String?
  acceptanceChecks String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  phase            Phase    @relation(fields: [phaseId], references: [id], onDelete: Cascade)
}

model Decision {
  id        String   @id @default(cuid())
  phaseId   String
  authorId  String?
  title     String
  rationale String
  impact    String?
  createdAt DateTime @default(now())
  phase     Phase    @relation(fields: [phaseId], references: [id], onDelete: Cascade)
  author    User?    @relation(fields: [authorId], references: [id], onUpdate: NoAction, onDelete: SetNull)

  @@index([phaseId])
  @@index([authorId])
}

model Problem {
  id          String   @id @default(cuid())
  phaseId     String
  authorId    String?
  title       String
  description String
  severity    String   @default("medium")
  status      String   @default("open")
  createdAt   DateTime @default(now())
  phase       Phase    @relation(fields: [phaseId], references: [id], onDelete: Cascade)
  author    User?    @relation(fields: [authorId], references: [id], onUpdate: NoAction, onDelete: SetNull)

  @@index([phaseId])
  @@index([authorId])
}

model Resolution {
  id          String   @id @default(cuid())
  phaseId     String
  authorId    String?
  summary     String
  details     String
  resolvedAt  DateTime @default(now())
  createdAt   DateTime @default(now())
  phase       Phase    @relation(fields: [phaseId], references: [id], onDelete: Cascade)
  author    User?    @relation(fields: [authorId], references: [id], onUpdate: NoAction, onDelete: SetNull)

  @@index([phaseId])
  @@index([authorId])
}

model DebugLog {
  id        String   @id @default(cuid())
  phaseId   String
  authorId  String?
  message   String
  level     String   @default("info")
  metadata  String?
  createdAt DateTime @default(now())
  phase     Phase    @relation(fields: [phaseId], references: [id], onDelete: Cascade)
  author    User?    @relation(fields: [authorId], references: [id], onUpdate: NoAction, onDelete: SetNull)

  @@index([phaseId])
  @@index([authorId])
}

model Artifact {
  id        String   @id @default(cuid())
  phaseId   String
  authorId  String?
  type      String
  name      String
  uri       String
  metadata  String?
  createdAt DateTime @default(now())
  phase     Phase    @relation(fields: [phaseId], references: [id], onDelete: Cascade)
  author    User?    @relation(fields: [authorId], references: [id], onUpdate: NoAction, onDelete: SetNull)

  @@index([phaseId])
  @@index([authorId])
}
