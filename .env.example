# App network
APP_PORT=8000

# Database service configuration
POSTGRES_DB=swarminsym
POSTGRES_USER=swarminsym
POSTGRES_PASSWORD=change_me

# SQLAlchemy connection string used by app/setup scripts
DATABASE_URL=postgresql+psycopg://swarminsym:change_me@db:5432/swarminsym

# Bootstrap admin account for first-time setup
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change_me_admin

# Backup storage directory on host
BACKUP_DIR=./backups
